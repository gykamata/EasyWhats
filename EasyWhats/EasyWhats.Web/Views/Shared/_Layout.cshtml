<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EasyWhats</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EasyWhats.Web.styles.css" asp-append-version="true" />
</head>

<body>

    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="ConfiguracaoSistema" asp-action="Index">
                📱 EasyWhats
            </a>
        </div>
        <div class="navbar-nav">
            <a class="nav-link text-white"
               asp-controller="ConfiguracaoSistema"
               asp-action="Index">
                Configuração
            </a>

            <a class="nav-link text-white"
               asp-controller="Mensagem"
               asp-action="Index">
                Enviar Mensagens
            </a>
        </div>
    </nav>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>