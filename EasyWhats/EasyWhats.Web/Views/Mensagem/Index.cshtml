@model EasyWhats.Web.Models.EnviarMensagemModel

@{
    ViewData["Title"] = "Enviar Mensagens";
}

<div class="card">

    <div class="card-header">
        <h3>Central de Envio</h3>
    </div>

    <div class="card-body">

        <form asp-action="Enviar" method="post">

            <div class="mb-3">

                <label asp-for="Numeros"></label>

                <textarea asp-for="Numeros"
                          class="form-control"
                          rows="8"
                          placeholder="Um número por linha&#10;ou separados por vírgula"></textarea>

                <span asp-validation-for="Numeros" class="text-danger"></span>

            </div>

            <div class="mb-3">

                <label asp-for="Mensagem"></label>

                <textarea asp-for="Mensagem"
                          class="form-control"
                          rows="6"></textarea>

                <span asp-validation-for="Mensagem" class="text-danger"></span>

            </div>

            <button class="btn btn-primary">
                Enviar
            </button>

        </form>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}